# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# https://console.cloud.google.com/apis/credentials
#
# Authorized JavaScript origins must include your site, e.g.:
#   http://localhost:5173
#   https://your-app.vercel.app
#
# For ANY Gmail user to sign in: OAuth consent screen → Publish app (In production).
# See PRODUCTION.md for the full checklist.

VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
